# ================================================================
#  Plane to Car — Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  Never commit your .env file to git.
# ================================================================


# ----------------------------------------------------------------
# SUPABASE
# Where to get these:
#   1. Go to https://supabase.com and open your project
#   2. Click "Project Settings" (gear icon, bottom-left sidebar)
#   3. Click "API" in the left menu
#
# SUPABASE_URL         → "Project URL" (looks like https://xxxx.supabase.co)
# SUPABASE_KEY         → "anon / public" key under "Project API keys"
# SUPABASE_SERVICE_ROLE_KEY → "service_role" key (same section, click reveal)
#   ⚠️  Keep the service_role key secret — it bypasses all Row Level Security
# ----------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service-role-key


# ----------------------------------------------------------------
# FLASK
# FLASK_ENV  → use "development" locally (enables debug mode + auto-reload)
#              change to "production" on your live server
# ----------------------------------------------------------------
FLASK_APP=main.py
FLASK_ENV=development


# ----------------------------------------------------------------
# SECRET KEY  (used to sign admin JWT tokens)
# Generate a strong random key by running this command in your terminal:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Paste the output below. Use a different value for production.
# ----------------------------------------------------------------
SECRET_KEY=paste-your-generated-hex-string-here


# ----------------------------------------------------------------
# CORS  (which frontend URLs are allowed to call this backend)
# Local dev:   http://localhost:5173
# Production:  https://yourdomain.com
# Multiple:    http://localhost:5173,https://yourdomain.com
# ----------------------------------------------------------------
FRONTEND_URL=http://localhost:5173


# ----------------------------------------------------------------
# ADMIN LOGIN CREDENTIALS
# These are used for the /api/auth/admin-login endpoint.
# They are NOT stored in Supabase — they live only in this file.
# Choose any email and strong password you want. Keep them secret.
# ----------------------------------------------------------------
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=choose-a-strong-password-here


# ----------------------------------------------------------------
# EMAIL / SMTP  (optional — all emails are silently skipped if not set)
#
# OPTION A — Gmail  (easiest to set up)
#   1. Your Gmail must have 2-Step Verification turned ON
#      → https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select app: "Mail", device: "Other" → type "Plane to Car" → Generate
#   4. Copy the 16-character app password shown (spaces don't matter)
#   5. Fill in below:
#      MAIL_SERVER=smtp.gmail.com
#      MAIL_PORT=587
#      MAIL_USE_TLS=true
#      MAIL_USERNAME=your-gmail@gmail.com
#      MAIL_PASSWORD=xxxx xxxx xxxx xxxx    ← the 16-char app password
#      MAIL_DEFAULT_SENDER=Plane to Car <your-gmail@gmail.com>
#
# OPTION B — Outlook / Hotmail
#      MAIL_SERVER=smtp-mail.outlook.com
#      MAIL_PORT=587
#      MAIL_USE_TLS=true
#      MAIL_USERNAME=your-email@outlook.com
#      MAIL_PASSWORD=your-outlook-password
#      MAIL_DEFAULT_SENDER=Plane to Car <your-email@outlook.com>
#
# OPTION C — Custom SMTP (e.g. Hostinger, Zoho, SendGrid)
#   Check your hosting panel / email provider for:
#   SMTP Host, Port (usually 587 or 465), Username, Password
#      MAIL_SERVER=mail.yourdomain.com
#      MAIL_PORT=587
#      MAIL_USE_TLS=true
#      MAIL_USERNAME=noreply@yourdomain.com
#      MAIL_PASSWORD=your-smtp-password
#      MAIL_DEFAULT_SENDER=Plane to Car <noreply@yourdomain.com>
# ----------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=Plane to Car <your-email@gmail.com>
